// https://pris.ly/d/prisma-schema
// Domain overview: docs/MAINTENANCE_DEBT_RADAR.md §3

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Auth & tenancy ---

enum MembershipRole {
  ADMIN
  MEMBER
  VIEWER
}

/// Login identity (global across orgs via memberships).
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  displayName  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships  Membership[]
  actionItems  ActionItem[] @relation("ActionItemOwner")
}

/// Root tenant (company / team using the radar).
model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  memberships           Membership[]
  services              Service[]
  integrationDeliveries IntegrationDelivery[]
  signalEvents          SignalEvent[]
  actionItems           ActionItem[]
}

/// User belongs to an org with exactly one role (RBAC).
model Membership {
  id             String          @id @default(cuid())
  userId         String
  organizationId String
  role           MembershipRole  @default(MEMBER)
  createdAt      DateTime        @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

// --- Services & repo mapping ---

/// A logical system inside an org (maps to one or more GitHub repos).
model Service {
  id             String   @id @default(cuid())
  name           String
  createdAt      DateTime @default(now())
  organizationId String

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  repoLinks    RepoLink[]
  actionItems  ActionItem[]

  @@index([organizationId])
}

/// Maps `owner/repo` (full name) to a service for webhook normalization.
model RepoLink {
  id           String   @id @default(cuid())
  serviceId    String
  /// GitHub `owner/name` (normalize casing in app if needed).
  repoFullName String
  createdAt    DateTime @default(now())

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, repoFullName])
  @@index([repoFullName])
}

// --- Ingestion & signals ---

/// Raw webhook inbox (GitHub retries → same `deliveryId` must dedupe).
model IntegrationDelivery {
  id             String    @id @default(cuid())
  organizationId String
  /// Value of `X-GitHub-Delivery` (or equivalent); unique for idempotency.
  deliveryId     String    @unique
  source           String    @default("github")
  /// `X-GitHub-Event` header, e.g. `workflow_run`.
  eventType        String?
  payload          Json
  receivedAt       DateTime  @default(now())
  processedAt      DateTime?
  processError     String?   @db.Text

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, receivedAt])
}

enum SignalEventSource {
  GITHUB
}

/// Normalized, immutable-ish facts derived from deliveries (dedupe by org + key).
model SignalEvent {
  id             String            @id @default(cuid())
  organizationId String
  source         SignalEventSource @default(GITHUB)
  /// e.g. `ci.workflow_run.failed` — keep as string for flexibility.
  eventType      String
  /// e.g. `github:workflow_run:12345` — prevents double-counting on webhook retries.
  dedupeKey      String
  occurredAt     DateTime
  repoFullName   String
  conclusion     String?
  payload        Json?

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actionItems  ActionItem[]

  @@unique([organizationId, dedupeKey])
  @@index([organizationId, occurredAt])
  @@index([organizationId, repoFullName])
}

// --- Work tracking ---

enum ActionItemStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

/// Triage backlog item (may be linked to a signal and/or service).
model ActionItem {
  id             String            @id @default(cuid())
  organizationId String
  serviceId      String?
  title          String
  description    String?           @db.Text
  /// 0 = unset; higher = more urgent (you can switch to an enum later).
  severity       Int               @default(0)
  status         ActionItemStatus  @default(OPEN)
  ownerUserId    String?
  dueAt          DateTime?
  /// Optional link to the signal that motivated this item.
  signalEventId  String?           @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  service      Service?       @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  owner        User?          @relation("ActionItemOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  signalEvent  SignalEvent?   @relation(fields: [signalEventId], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@index([organizationId, serviceId])
}
