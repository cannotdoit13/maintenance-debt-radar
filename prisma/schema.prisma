// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Root tenant (company / team using the radar).
model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
}
