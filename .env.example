# Copy to .env and adjust. Used by Prisma and the app.
DATABASE_URL="postgresql://radar:radar@localhost:5432/maintenance_debt_radar?schema=public"
PORT=3000
HOST=0.0.0.0

# Required for production: random string >= 16 characters (used to sign JWTs).
JWT_SECRET="replace-with-a-long-random-secret"

# Shared secret configured in GitHub webhook settings (used for HMAC verification).
GITHUB_WEBHOOK_SECRET="replace-with-your-github-webhook-secret"

# How often the normalizer worker polls for new deliveries (milliseconds). Default: 5000.
NORMALIZER_POLL_MS=5000
